"@ | Out-File -FilePath ".gitignore" -Encoding utf8 -Force

# 4. Commit & push inicial
git add .gitignore
git commit -m "chore: init repo with multi-stack .gitignore (Laravel+Node+Docker+IDE)"
git push origin main

# 5. Criar branches do backlog
git checkout -b develop
git push origin develop

